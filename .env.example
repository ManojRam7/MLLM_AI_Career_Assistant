# Copy to .env for local runs. In GitHub Actions these go in repo Settings > Secrets.
# Everything here is free-tier.

# --- Job sources (free/official) ---
REED_API_KEY=                 # https://www.reed.co.uk/developers (free)
ADZUNA_APP_ID=                # https://developer.adzuna.com (free)
ADZUNA_APP_KEY=

# --- Storage ---
SUPABASE_DB_URL=              # Supabase > Project Settings > Database > Connection string (psql/URI)

# --- LLMs (free tiers) ---
GEMINI_API_KEY=               # https://aistudio.google.com/app/apikey (free)
GROQ_API_KEY=                 # https://console.groq.com/keys (free)

# --- Optional / paid (leave blank to skip) ---
APIFY_TOKEN=                  # paid: LinkedIn/Indeed/Glassdoor/Google actors
SERPAPI_KEY=                  # paid: Google Jobs
TELEGRAM_BOT_TOKEN=           # optional digest notifications
TELEGRAM_CHAT_ID=
