# Copy to .env for local runs. In GitHub Actions these go in repo Settings > Secrets.

# --- Job sources (free/official) ---
REED_API_KEY=                 # https://www.reed.co.uk/developers (free)
ADZUNA_APP_ID=                # https://developer.adzuna.com (free)
ADZUNA_APP_KEY=

# --- Storage ---
SUPABASE_DB_URL=              # Supabase > Project Settings > Database > Connection string (psql/URI)

# --- LLMs (parallel routing: scoring->DeepSeek, recommendations->Gemini) ---
GEMINI_API_KEY=               # https://aistudio.google.com/app/apikey (Gemini for recommendations)
GROQ_API_KEY=                 # https://console.groq.com/keys (free; fast fallback)
DEEPSEEK_API_KEY=             # https://platform.deepseek.com (cheap; high-volume fit-scoring)

# --- Job search (Bright Data SERP API - Google job search) ---
BRIGHTDATA_API_KEY=           # Bright Data > Account Settings (create a SERP API zone first)
BRIGHTDATA_SERP_ZONE=serp     # the SERP zone name you created in the Bright Data control panel
BRIGHTDATA_LINKEDIN_DATASET=  # (optional) Bright Data LinkedIn dataset_id - OFF by default ($250 min order)

# --- LinkedIn via cheap Apify actor (valig/linkedin-jobs-scraper), per-company. ~$0.0004/result ---
APIFY_TOKEN_1=                # https://console.apify.com/account/integrations (multiple rotate on exhaustion)
APIFY_TOKEN_2=
APIFY_TOKEN_3=
APIFY_TOKEN_4=

# --- Telegram job alerts ---
TELEGRAM_BOT_TOKEN=           # @BotFather
TELEGRAM_CHAT_ID=             # your chat id (message @userinfobot)
