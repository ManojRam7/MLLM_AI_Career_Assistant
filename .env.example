# Copy to .env for local runs. In GitHub Actions these go in repo Settings > Secrets.
# Everything here is free-tier.

# --- Job sources (free/official) ---
REED_API_KEY=                 # https://www.reed.co.uk/developers (free)
ADZUNA_APP_ID=                # https://developer.adzuna.com (free)
ADZUNA_APP_KEY=

# --- Storage ---
SUPABASE_DB_URL=              # Supabase > Project Settings > Database > Connection string (psql/URI)

# --- LLMs (parallel routing: scoring->DeepSeek, tailoring->Gemini Pro) ---
GEMINI_API_KEY=               # https://aistudio.google.com/app/apikey (Gemini 2.5 Pro for tailoring)
GROQ_API_KEY=                 # https://console.groq.com/keys (free; fast fallback)
DEEPSEEK_API_KEY=             # https://platform.deepseek.com (cheap; high-volume fit-scoring)

# --- Job scraping (Apify Google-Jobs actor; multiple tokens rotate on exhaustion) ---
APIFY_TOKEN_1=                # https://console.apify.com/account/integrations
APIFY_TOKEN_2=
APIFY_TOKEN_3=
APIFY_TOKEN_4=

# --- Telegram job alerts ---
TELEGRAM_BOT_TOKEN=           # @BotFather
TELEGRAM_CHAT_ID=             # your chat id (message @userinfobot)
